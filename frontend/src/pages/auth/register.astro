---
import Layout from '../../layouts/Layout.astro'
---

<Layout title="Registro">
  <div class="container vh-100 d-flex align-items-center justify-content-center">
    <div class="card shadow" style="width: 100%; max-width: 420px;">
      <div class="card-body p-5">

        <h4 class="card-title text-center mb-4">Crear cuenta</h4>

        <div id="error" class="alert alert-danger d-none"></div>
        <div id="exito" class="alert alert-success d-none"></div>

        <div class="mb-3">
          <label for="nombre" class="form-label">Nombre</label>
          <input type="text" class="form-control" id="nombre" placeholder="Tu nombre" />
        </div>

        <div class="mb-3">
          <label for="apellido" class="form-label">Apellido</label>
          <input type="text" class="form-control" id="apellido" placeholder="Tu apellido" />
        </div>

        <div class="mb-3">
          <label for="correo" class="form-label">Correo electrónico</label>
          <input type="email" class="form-control" id="correo" placeholder="correo@ejemplo.com" />
        </div>

        <div class="mb-3">
          <label for="usuario" class="form-label">Nombre de usuario</label>
          <input type="text" class="form-control" id="usuario" placeholder="usuario123" />
        </div>

        <div class="mb-4">
          <label for="contrasena" class="form-label">Contraseña</label>
          <input type="password" class="form-control" id="contrasena" placeholder="••••••••" />
        </div>

        <div class="d-grid">
          <button class="btn btn-primary" id="btnRegistrar">Registrarse</button>
        </div>

        <p class="text-center mt-4 mb-0">
          ¿Ya tienes cuenta? <a href="/auth/login">Inicia sesión</a>
        </p>

      </div>
    </div>
  </div>
</Layout>

<script>
  import { register } from '../../services/auth.service.js'

  document.getElementById('btnRegistrar').addEventListener('click', async () => {
    const nombre = document.getElementById('nombre').value.trim()
    const apellido = document.getElementById('apellido').value.trim()
    const correo_electronico = document.getElementById('correo').value.trim()
    const nombre_usuario = document.getElementById('usuario').value.trim()
    const contrasena = document.getElementById('contrasena').value.trim()
    const errorDiv = document.getElementById('error')
    const exitoDiv = document.getElementById('exito')

    errorDiv.classList.add('d-none')
    exitoDiv.classList.add('d-none')

    try {
      await register({ nombre, apellido, correo_electronico, nombre_usuario, contrasena })
      exitoDiv.textContent = 'Cuenta creada correctamente, redirigiendo...'
      exitoDiv.classList.remove('d-none')
      setTimeout(() => window.location.href = '/auth/login', 1500)
    } catch (error) {
      errorDiv.textContent = error.message
      errorDiv.classList.remove('d-none')
    }
  })
</script>