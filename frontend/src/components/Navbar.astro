    </div>
  </div>
</nav>

<script>
  import { logout, getNombre, getRol } from '../services/auth.service.js'

  const nombre = getNombre()
  const rol = getRol()

  if (nombre) document.getElementById('navNombre').textContent = nombre

  if (rol === 'admin') {
    document.getElementById('navAdmin').classList.remove('d-none')
  }

  document.getElementById('btnLogout').addEventListener('click', () => {
    logout()
  })
</script>